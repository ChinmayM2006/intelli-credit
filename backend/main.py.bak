        return [d.to_dict() for d in docs]
    finally:
        db.close()


# ── Research ──

@app.post("/applications/{app_id}/research")
async def run_research(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        promoters = [n.strip() for n in (app_obj.promoter_names or "").split(",") if n.strip()]

        result = await research_agent.research_company(
            company_name=app_obj.company_name,
            promoter_names=promoters,
            industry=app_obj.industry or "",
        )

        app_obj.research = json.dumps(result)
        app_obj.stage = "research_done"
        db.commit()

        return result
    finally:
        db.close()


