# ── Scoring + Analysis ──

@app.post("/applications/{app_id}/score")
def score_application(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        app_dict = _build_app_dict(app_obj, db)

        result = scorer.score(app_dict)

        app_obj.risk_score = json.dumps(result)
        app_obj.stage = "scored"
        db.commit()

        return result
    finally:
        db.close()


@app.post("/applications/{app_id}/swot")
def generate_swot_analysis(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        parsed_data = json.loads(app_obj.parsed_data or "{}")
        research_data = json.loads(app_obj.research or "{}")
        risk_score = json.loads(app_obj.risk_score or "{}")

        # Need ML result for SWOT
        ml_result = risk_score.get("ml_prediction", {})
        if not ml_result:
            ml_result = predict_default(parsed_data)

        result = generate_swot(parsed_data, research_data, ml_result, app_obj.company_name)

        app_obj.swot = json.dumps(result)
        db.commit()

        return result
    finally:
        db.close()


@app.post("/applications/{app_id}/triangulate")
def run_triangulation(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        parsed_data = json.loads(app_obj.parsed_data or "{}")
        research_data = json.loads(app_obj.research or "{}")
        risk_score = json.loads(app_obj.risk_score or "{}")

        ml_result = risk_score.get("ml_prediction", {})
        if not ml_result:
            ml_result = predict_default(parsed_data)

        result = triangulate(parsed_data, research_data, ml_result)

        app_obj.triangulation = json.dumps(result)
        db.commit()

        return result
    finally:
        db.close()


# ── CAM / Report Generation ──

@app.post("/applications/{app_id}/generate-report")
def generate_report(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        app_dict = _build_app_dict(app_obj, db)

        # Add all computed data
        app_dict["risk_score"] = json.loads(app_obj.risk_score or "{}")
        app_dict["swot"] = json.loads(app_obj.swot or "{}")
        app_dict["triangulation"] = json.loads(app_obj.triangulation or "{}")

        output_path = cam_generator.generate(app_dict, OUTPUT_DIR)
        app_obj.cam_path = output_path
        app_obj.stage = "report_generated"
        db.commit()

        return {"status": "generated", "path": output_path, "filename": os.path.basename(output_path)}
    finally:
        db.close()


@app.get("/applications/{app_id}/download-report")
def download_report(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        company = app_obj.company_name.replace(" ", "_")
        pattern = f"CAM_{app_id}_{company}.pdf"
        filepath = os.path.join(OUTPUT_DIR, pattern)
        if not os.path.exists(filepath):
            # Try to find any matching file
            for f in os.listdir(OUTPUT_DIR):
                if app_id in f and f.endswith(".pdf"):
                    filepath = os.path.join(OUTPUT_DIR, f)
                    break
            else:
                raise HTTPException(status_code=404, detail="Report not generated yet")
        return FileResponse(filepath, filename=pattern, media_type="application/pdf")
    finally:
        db.close()


# ── Full Pipeline (one-click) ──

@app.post("/applications/{app_id}/run-pipeline")
async def run_full_pipeline(app_id: str):
    """Run the complete analysis pipeline: research → score → swot → triangulate."""
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        app_dict = _build_app_dict(app_obj, db)
        results = {"stages": []}

        # 1. Research
        try:
            promoters = [n.strip() for n in (app_obj.promoter_names or "").split(",") if n.strip()]
            research = await research_agent.research_company(
                app_obj.company_name, promoters, app_obj.industry or ""
            )
            app_obj.research = json.dumps(research)
            results["stages"].append({"stage": "research", "status": "done"})
        except Exception as e:
            results["stages"].append({"stage": "research", "status": "error", "error": str(e)})
            research = {}

        # 2. Score
        try:
            app_dict["research"] = research
            score_result = scorer.score(app_dict)
            app_obj.risk_score = json.dumps(score_result)
            results["stages"].append({"stage": "scoring", "status": "done"})
        except Exception as e:
            results["stages"].append({"stage": "scoring", "status": "error", "error": str(e)})
            score_result = {}

        # 3. SWOT
        try:
            parsed_data = json.loads(app_obj.parsed_data or "{}")
            ml_result = score_result.get("ml_prediction", predict_default(parsed_data))
            swot = generate_swot(parsed_data, research, ml_result, app_obj.company_name)
            app_obj.swot = json.dumps(swot)
            results["stages"].append({"stage": "swot", "status": "done"})
        except Exception as e:
            results["stages"].append({"stage": "swot", "status": "error", "error": str(e)})

        # 4. Triangulation
        try:
            tri = triangulate(parsed_data, research, ml_result)
            app_obj.triangulation = json.dumps(tri)
            results["stages"].append({"stage": "triangulation", "status": "done"})
        except Exception as e:
            results["stages"].append({"stage": "triangulation", "status": "error", "error": str(e)})

        app_obj.stage = "scored"
        db.commit()

        # Return full application state
        results["application"] = _build_app_dict(app_obj, db)
        results["application"]["risk_score"] = json.loads(app_obj.risk_score or "{}")
        results["application"]["swot"] = json.loads(app_obj.swot or "{}")
        results["application"]["triangulation"] = json.loads(app_obj.triangulation or "{}")
        results["application"]["research"] = json.loads(app_obj.research or "{}")

        return results
    finally:
        db.close()


