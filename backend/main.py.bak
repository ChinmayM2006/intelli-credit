"""
Intelli-Credit Engine v2 — FastAPI Application
Full-featured Credit Decisioning Engine with:
- Multi-step onboarding with document upload
- Auto-classification + human-in-the-loop
- ML-based risk scoring + Altman Z-Score
- Loan structuring (DSCR/Turnover/NW/ALM)
- SWOT analysis + Data triangulation
- Final Investment Report (CAM) generation
"""
import os
import sys
import json
import uuid
import shutil
from datetime import datetime
from typing import Dict, Any, List, Optional

from fastapi import FastAPI, UploadFile, File, Form, HTTPException, Depends
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import FileResponse
from pydantic import BaseModel

# ── Fix import paths ──
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from backend.config import UPLOAD_DIR, OUTPUT_DIR
from backend.database import init_db, get_db, Application, Document, PrimaryInsight
from backend.llm.provider import get_llm_status
from backend.ingestor.parser import parse_document
from backend.ingestor.classifier import classify_document, classify_with_llm
from backend.ingestor.llm_extractor import extract_with_llm
from backend.engine.risk_scorer import CreditRiskScorer
from backend.engine.swot_generator import generate_swot
from backend.engine.ml.predictor import predict_default
from backend.engine.ml.altman_z import calculate_altman_z
from backend.engine.loan_structurer import structure_loan
from backend.engine.cam_generator import CAMGenerator
from backend.research.agent import ResearchAgent
from backend.research.triangulator import triangulate


# ── App Setup ──
app = FastAPI(title="Intelli-Credit Engine", version="2.0")
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Ensure directories exist
os.makedirs(UPLOAD_DIR, exist_ok=True)
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Init database
init_db()

# Singletons
scorer = CreditRiskScorer()
research_agent = ResearchAgent()
cam_generator = CAMGenerator()


# ── Pydantic Models ──

class ApplicationCreate(BaseModel):
    company_name: str
    cin: Optional[str] = ""
    industry: Optional[str] = ""
    incorporation_year: Optional[int] = None
    promoter_names: Optional[str] = ""
    loan_amount_requested: Optional[float] = 0
    loan_purpose: Optional[str] = ""
    loan_type: Optional[str] = "term_loan"
    loan_tenure_requested: Optional[int] = 0

class InsightCreate(BaseModel):
    content: str
    note_type: Optional[str] = "site_visit"
    officer_name: Optional[str] = ""

class ClassificationConfirm(BaseModel):
    doc_type: str


# ── Helper ──

def _get_app_or_404(app_id: str, db) -> Application:
    app_obj = db.query(Application).filter(Application.id == app_id).first()
    if not app_obj:
        raise HTTPException(status_code=404, detail="Application not found")
    return app_obj


def _build_app_dict(app_obj: Application, db) -> Dict[str, Any]:
    """Build the full dict needed by scorer/research etc."""
    d = app_obj.to_dict()
    docs = db.query(Document).filter(Document.application_id == app_obj.id).all()
    d["documents"] = [doc.to_dict() for doc in docs]
    insights = db.query(PrimaryInsight).filter(PrimaryInsight.application_id == app_obj.id).all()
    d["primary_insights"] = [i.to_dict() for i in insights]
    return d


# ═══════════════════════════════════════════════════════════════════════════════
# ENDPOINTS
# ═══════════════════════════════════════════════════════════════════════════════

# ── Health ──

@app.get("/health")
def health():
    llm = get_llm_status()
    return {
        "status": "healthy",
        "version": "2.0",
        "llm_provider": llm["provider"],
        "llm_mode": llm["mode"],
    }


# ── Applications CRUD ──

@app.post("/applications")
def create_application(data: ApplicationCreate):
    db = next(get_db())
    try:
        app_obj = Application(
            id=str(uuid.uuid4())[:8],
            company_name=data.company_name,
            cin=data.cin or "",
            industry=data.industry or "",
            incorporation_year=data.incorporation_year,
            promoter_names=data.promoter_names or "",
            loan_amount_requested=data.loan_amount_requested or 0,
            loan_purpose=data.loan_purpose or "",
            loan_type=data.loan_type or "term_loan",
            loan_tenure_requested=data.loan_tenure_requested or 0,
            stage="onboarding",
        )
        db.add(app_obj)
        db.commit()
        db.refresh(app_obj)
        return app_obj.to_dict()
    finally:
        db.close()


@app.get("/applications")
def list_applications():
    db = next(get_db())
    try:
        apps = db.query(Application).order_by(Application.created_at.desc()).all()
        return [a.to_dict() for a in apps]
    finally:
        db.close()


@app.get("/applications/{app_id}")
def get_application(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        return _build_app_dict(app_obj, db)
    finally:
        db.close()


@app.delete("/applications/{app_id}")
def delete_application(app_id: str):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)
        db.delete(app_obj)
        db.commit()
        return {"status": "deleted"}
    finally:
        db.close()


# ── Document Upload + Auto-Classification ──

@app.post("/applications/{app_id}/upload")
async def upload_document(
    app_id: str,
    file: UploadFile = File(...),
    doc_type: Optional[str] = Form(None),
):
    db = next(get_db())
    try:
        app_obj = _get_app_or_404(app_id, db)

        # Save file
        app_upload_dir = os.path.join(UPLOAD_DIR, app_id)
        os.makedirs(app_upload_dir, exist_ok=True)
        file_path = os.path.join(app_upload_dir, file.filename)
        with open(file_path, "wb") as f:
            content = await file.read()
            f.write(content)

        # Auto-classify if no type provided
        if not doc_type:
            classification = classify_document(file_path, file.filename)
            # Try LLM classification if uncertain
            if classification.get("needs_review", True):
                llm_class = await classify_with_llm(file_path, file.filename)
                if llm_class and llm_class.get("confidence", 0) > classification.get("confidence", 0):
                    classification = llm_class
            doc_type = classification.get("predicted_type", "other")
            confidence = classification.get("confidence", 0)
            needs_review = classification.get("needs_review", True)
        else:
            confidence = 1.0
            needs_review = False
            classification = {"predicted_type": doc_type, "confidence": 1.0}

        # Parse document
        try:
            parsed = parse_document(file_path, doc_type)
        except Exception as e:
            parsed = {"doc_type": doc_type, "error": str(e), "fields": {}, "risks": []}

        # Try LLM extraction for richer data
        try:
            llm_extracted = await extract_with_llm(file_path, doc_type)
            if llm_extracted:
                # Merge LLM data into parsed fields
                existing_fields = parsed.get("fields", {})
                for k, v in llm_extracted.items():
                    if k not in existing_fields or not existing_fields[k]:
                        existing_fields[k] = v
                parsed["fields"] = existing_fields
                parsed["llm_enhanced"] = True
        except Exception:
            pass

        # Save document record
        doc = Document(
            id=str(uuid.uuid4())[:8],
            application_id=app_id,
            filename=file.filename,
            file_path=file_path,
            doc_type=doc_type,
            classification_confidence=confidence,
            classification_evidence=json.dumps(classification) if isinstance(classification, dict) else None,
            confirmed=not needs_review,
            parsed_summary=parsed.get("summary", ""),
            extracted_fields_json=json.dumps(parsed.get("fields", {})),
            risks_json=json.dumps(parsed.get("risks", [])),
        )
        db.add(doc)

        # Update application's parsed_data
        current_parsed = json.loads(app_obj.parsed_data or "{}")
        current_parsed[doc_type] = parsed
        app_obj.parsed_data = json.dumps(current_parsed)
        app_obj.stage = "documents_uploaded"

        db.commit()
        db.refresh(doc)

        return {
            "document": doc.to_dict(),
            "classification": classification,
            "parsed_summary": parsed.get("summary", ""),
            "risks_found": len(parsed.get("risks", [])),
        }
    finally:
        db.close()


@app.put("/applications/{app_id}/documents/{doc_id}/confirm")
def confirm_classification(app_id: str, doc_id: str, data: ClassificationConfirm):
    """Human-in-the-loop: confirm or override document classification."""
    db = next(get_db())
    try:
        doc = db.query(Document).filter(Document.id == doc_id, Document.application_id == app_id).first()
        if not doc:
            raise HTTPException(status_code=404, detail="Document not found")

        old_type = doc.doc_type
        new_type = data.doc_type

        if old_type != new_type:
            # Re-parse with correct type
            try:
                parsed = parse_document(doc.file_path, new_type)
                doc.parsed_data = json.dumps(parsed)
            except Exception:
                pass

            # Update application's parsed_data
            app_obj = _get_app_or_404(app_id, db)
            current_parsed = json.loads(app_obj.parsed_data or "{}")
            if old_type in current_parsed:
                del current_parsed[old_type]
            current_parsed[new_type] = json.loads(doc.parsed_data or "{}")
            app_obj.parsed_data = json.dumps(current_parsed)

        doc.doc_type = new_type
        doc.confirmed = True
        doc.needs_review = False
        doc.classification_confidence = 1.0
        db.commit()

        return {"status": "confirmed", "doc_type": new_type}
    finally:
        db.close()


@app.get("/applications/{app_id}/documents")
def list_documents(app_id: str):
