@app.post("/demo/populate")
def populate_demo():
    """Create a demo application with pre-filled data for hackathon showcase."""
    db = next(get_db())
    try:
        app_obj = Application(
            id="demo-001",
            company_name="Bharat Industries Pvt Ltd",
            cin="U28100MH2015PTC268500",
            industry="Manufacturing - Auto Components",
            incorporation_year=2015,
            promoter_names="Rajesh Kumar, Priya Sharma",
            loan_amount_requested=50.0,
            loan_purpose="Capacity expansion and working capital",
            loan_type="term_loan",
            loan_tenure_requested=5,
            stage="onboarding",
            parsed_data=json.dumps(_demo_parsed_data()),
            research=json.dumps(_demo_research()),
        )
        # Check if already exists
        existing = db.query(Application).filter(Application.id == "demo-001").first()
        if existing:
            db.delete(existing)
            db.commit()
        db.add(app_obj)
        db.commit()
        return {"status": "demo_created", "app_id": "demo-001"}
    finally:
        db.close()


